# Copy to .env.local (Next.js) and/or .env (Hardhat). Never commit real values.
#
# SECRET (server / CLI only — must stay out of git):
#   PRIVATE_KEY          Hardhat deployer wallet
#   BASESCAN_API_KEY     Contract verification
#
# PUBLIC (safe in client bundle; still use env vars, not hardcoded secrets):
#   NEXT_PUBLIC_*        Exposed in the browser by design

# Hardhat / Base mainnet deployment
PRIVATE_KEY=
BASESCAN_API_KEY=
BASE_RPC_URL=https://mainnet.base.org

# Next.js frontend (use .env.local for local dev)
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=